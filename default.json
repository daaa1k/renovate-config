{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "minimumReleaseAge": "5 days",
  "schedule": ["* 10-14 * * 6"],
  "timezone": "Asia/Tokyo",
  "assignees": ["daaa1k"],
  "prConcurrentLimit": 10,
  "commitMessageAction": "update",
  "github-actions": {
    "managerFilePatterns": [
      "/(^|/)\\.(?:github|gitea|forgejo)/(?:workflows|actions)/.+\\.ya?ml\\.jinja$/"
    ]
  },
  "mise": {
    "managerFilePatterns": ["**/mise.toml.jinja"]
  },
  "packageRules": [
    {
      "description": "Group GitHub Actions patch updates into one PR",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch"],
      "groupName": "github-actions patch",
      "commitMessagePrefix": "ci:"
    },
    {
      "description": "Prefix non-patch GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "ci:"
    },
    {
      "description": "Do not apply minimum release age to my GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["daaa1k/{/,}**"],
      "minimumReleaseAge": null
    },
    {
      "description": "Group mise patch updates into one PR",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["patch"],
      "groupName": "mise patch dependencies",
      "commitMessagePrefix": "chore:"
    },
    {
      "description": "Prefix non-patch mise updates",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "chore:"
    },
    {
      "description": "Group Go module patch updates into one PR",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go patch dependencies",
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Prefix non-patch Go module updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Group Bun patch updates into one PR",
      "matchManagers": ["bun"],
      "matchUpdateTypes": ["patch"],
      "groupName": "bun patch",
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Prefix Bun module updates",
      "matchManagers": ["bun"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Group NPM module patch updates into one PR",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "npm patch dependencies",
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Prefix non-patch NPM module updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major", "minor"],
      "commitMessagePrefix": "build:"
    },
    {
      "description": "Do not apply minimum release age to copier",
      "matchManagers": ["copier"],
      "minimumReleaseAge": null,
      "commitMessagePrefix": "chore:"
    }
  ]
}
